venv/
__pycache__/
*.pyc
.env

# dados brutos: apenas os arquivos usados em runtime pela API sobem
data/raw/*
!data/raw/results.csv
!data/raw/fifa_ranking-2023-07-20.csv
!data/raw/fifa_ranking-2024-04-04.csv
!data/raw/fifa_ranking-2024-06-20.csv
